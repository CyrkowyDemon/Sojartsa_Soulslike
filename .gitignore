# Standardowy, bezpieczny .gitignore dla Unity (Wersja Profesjonalna)

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
.utmp/

# Logi i zrzuty pamięci
*.log
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Pliki projektowe IDE
/[Aa]ssets/Plugins/Editor/JetBrains*
*.DotSettings.user
.vs/
.gradle/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Systemy crashów i kompilacji
sysinfo.txt
mono_crash.*
crashlytics-build.properties

# Formaty wynikowe (Buildy)
*.apk
*.aab
*.unitypackage

# Lokalne pliki cache narzędzi (Te co sypały błędami)
.cache/
*.fobj

# Addressables - ignoruj tylko wygenerowane pliki binarne i temp
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
/[Aa]ssets/[Ss]treamingAssets/aa/*
!/[Aa]ssets/[Ss]treamingAssets/aa/Settings.json

# FMOD Cache (Dodatkowe zabezpieczenie)
.cache/fsbcache/
